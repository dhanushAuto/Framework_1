package ai.prompt;

import ai.model.SonarIssue;

public final class SonarPromptBuilder {

    private SonarPromptBuilder() {
    }


    public static String buildPrompt(SonarIssue issue, String sourceCode) {
        return buildBatchPrompt(java.util.List.of(issue), sourceCode);
    }

    public static String buildBatchPrompt(java.util.List<SonarIssue> issues, String sourceCode) {

        StringBuilder prompt = new StringBuilder();

        prompt.append("""
You are a Senior Java Automation Architect.

Fix ALL the reported SonarQube issues in the provided Java source code.

Requirements:

1. Do not change business logic.
2. Preserve all comments and existing code structure.
3. Keep formatting clean.
4. Follow Java 21 best practices and Clean Code principles.
5. Fix ONLY the reported issues listed below.
6. Return ONLY the COMPLETE corrected Java source code.
7. Do not explain anything.
8. Do not wrap code inside markdown or any other tags.
9. Ensure the code is valid and compiles.
10. If an issue is a missing private constructor in a utility class, add it.
11. If multiple issues are in the same file, apply all fixes.

""");

        prompt.append("\n-----------------------------------\n");
        prompt.append("SONAR ISSUES TO FIX\n");
        prompt.append("-----------------------------------\n");

        for (SonarIssue issue : issues) {
            prompt.append("Issue: ").append(issue.getMessage())
                    .append(" (Rule: ").append(issue.getRule())
                    .append(", Line: ").append(issue.getLine())
                    .append(")\n");
        }

        prompt.append("\n-----------------------------------\n");
        prompt.append("SOURCE CODE\n");
        prompt.append("(Only relevant method)\n");
        prompt.append("-----------------------------------\n");

        prompt.append(sourceCode);
        System.out.println("Prompt Length = " + prompt.length());

        return prompt.toString();
    }
}