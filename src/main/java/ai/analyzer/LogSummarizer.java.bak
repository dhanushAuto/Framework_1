package ai.analyzer;

import ai.service.AIService;

import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

public class LogSummarizer {

    private final AIService aiService = new AIService();

    public String ask(String prompt) throws Exception {
        return client.generateResponse(prompt);
    }
            You are a Log Analysis Expert.
            
            Summarize the following log content.
            
            Context: %s
            
            Log Content:
            %s
            
            Provide:
            1. SUMMARY: Brief summary of the log
            2. KEY_EVENTS: List of key events
            3. ERROR_COUNT: Number of errors
            4. WARNING_COUNT: Number of warnings
            5. OVERALL_STATUS: HEALTHY/DEGRADED/CRITICAL
            
            Format:
            SUMMARY: [Summary text]
            KEY_EVENTS: event1, event2, event3
            ERROR_COUNT: 5
            WARNING_COUNT: 12
            OVERALL_STATUS: DEGRADED
            """.formatted(context, truncatedLog);
    }

    private String buildIssueExtractionPrompt(String logContent) {
        String truncatedLog = logContent.length() > 5000 ? logContent.substring(0, 5000) + "..." : logContent;
        
        return """
            You are a Log Issue Extraction Expert.
            
            Extract all issues (errors, exceptions, warnings) from the log.
            
            Log Content:
            %s
            
            For each issue, provide:
            1. Timestamp
            2. Severity
            3. Message
            4. Component
            
            Format:
            [TIMESTAMP] | SEVERITY | MESSAGE | COMPONENT
            One per line.
            """.formatted(truncatedLog);
    }

    private String buildPatternAnalysisPrompt(String logContent) {
        String truncatedLog = logContent.length() > 5000 ? logContent.substring(0, 5000) + "..." : logContent;
        
        return """
            You are a Log Pattern Analysis Expert.
            
            Analyze patterns in the log and count occurrences.
            
            Log Content:
            %s
            
            Identify and count:
            1. Error patterns
            2. Warning patterns
            3. Info patterns
            4. Repeated messages
            
            Format:
            PATTERN_NAME: COUNT
            One per line.
            """.formatted(truncatedLog);
    }

    private String buildInsightsPrompt(String logContent, String timeRange) {
        String truncatedLog = logContent.length() > 5000 ? logContent.substring(0, 5000) + "..." : logContent;
        
        return """
            You are a Log Insights Expert.
            
            Generate actionable insights from the log data.
            
            Time Range: %s
            
            Log Content:
            %s
            
            Provide insights on:
            1. System health trends
            2. Recurring issues
            3. Performance anomalies
            4. Recommended actions
            5. Areas requiring attention
            """.formatted(timeRange, truncatedLog);
    }

    private LogSummary parseLogSummary(String aiResponse) {
        LogSummary summary = new LogSummary();
        
        String[] lines = aiResponse.split("\n");
        for (String line : lines) {
            if (line.startsWith("SUMMARY:")) {
                summary.setSummary(line.split(":", 2)[1].trim());
            } else if (line.startsWith("KEY_EVENTS:")) {
                summary.setKeyEvents(extractList(line.split(":", 2)[1]));
            } else if (line.startsWith("ERROR_COUNT:")) {
                summary.setErrorCount(Integer.parseInt(line.split(":")[1].trim()));
            } else if (line.startsWith("WARNING_COUNT:")) {
                summary.setWarningCount(Integer.parseInt(line.split(":")[1].trim()));
            } else if (line.startsWith("OVERALL_STATUS:")) {
                summary.setOverallStatus(line.split(":")[1].trim());
            }
        }
        
        return summary;
    }

    private List<LogIssue> parseLogIssues(String aiResponse) {
        List<LogIssue> issues = new ArrayList<>();
        String[] lines = aiResponse.split("\n");
        for (String line : lines) {
            if (line.contains("|")) {
                String[] parts = line.split("\\|");
                if (parts.length >= 4) {
                    LogIssue issue = new LogIssue();
                    issue.setTimestamp(parts[0].trim());
                    issue.setSeverity(parts[1].trim());
                    issue.setMessage(parts[2].trim());
                    issue.setComponent(parts[3].trim());
                    issues.add(issue);
                }
            }
        }
        return issues;
    }

    private Map<String, Integer> parseLogPatterns(String aiResponse) {
        Map<String, Integer> patterns = new HashMap<>();
        String[] lines = aiResponse.split("\n");
        for (String line : lines) {
            if (line.contains(":")) {
                String[] parts = line.split(":");
                if (parts.length == 2) {
                    try {
                        patterns.put(parts[0].trim(), Integer.parseInt(parts[1].trim()));
                    } catch (NumberFormatException e) {
                        // Skip invalid lines
                    }
                }
            }
        }
        return patterns;
    }

    private List<String> extractList(String str) {
        String[] items = str.trim().split(",");
        List<String> result = new ArrayList<>();
        for (String item : items) {
            result.add(item.trim());
        }
        return result;
    }

    public static class LogSummary {
        private String summary = "";
        private List<String> keyEvents = new ArrayList<>();
        private int errorCount = 0;
        private int warningCount = 0;
        private String overallStatus = "HEALTHY";

        public String getSummary() { return summary; }
        public void setSummary(String summary) { this.summary = summary; }
        
        public List<String> getKeyEvents() { return keyEvents; }
        public void setKeyEvents(List<String> keyEvents) { this.keyEvents = keyEvents; }
        
        public int getErrorCount() { return errorCount; }
        public void setErrorCount(int errorCount) { this.errorCount = errorCount; }
        
        public int getWarningCount() { return warningCount; }
        public void setWarningCount(int warningCount) { this.warningCount = warningCount; }
        
        public String getOverallStatus() { return overallStatus; }
        public void setOverallStatus(String overallStatus) { this.overallStatus = overallStatus; }
    }

    public static class LogIssue {
        private String timestamp = "";
        private String severity = "";
        private String message = "";
        private String component = "";

        public String getTimestamp() { return timestamp; }
        public void setTimestamp(String timestamp) { this.timestamp = timestamp; }
        
        public String getSeverity() { return severity; }
        public void setSeverity(String severity) { this.severity = severity; }
        
        public String getMessage() { return message; }
        public void setMessage(String message) { this.message = message; }
        
        public String getComponent() { return component; }
        public void setComponent(String component) { this.component = component; }
    }
}